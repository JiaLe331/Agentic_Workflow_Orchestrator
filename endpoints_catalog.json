{
    "endpoints": [
        {
            "name": "parse_pdf_universal",
            "url": "http://localhost:8000/api/parse-pdf",
            "method": "POST",
            "description": "Universal PDF parser - extracts ALL entities automatically from ANY PDF type (no schema needed)",
            "category": "pdf_parser",
            "input": {
                "file": "PDF file upload (binary) - ANY document type"
            },
            "output": {
                "success": "boolean",
                "data": "Extracted JSON object with all relevant entities (fields vary by document type)",
                "filename": "Original PDF filename",
                "error": "Error message if failed (optional)"
            },
            "use_cases": [
                "Employee forms → extracts name, email, department, job_title, start_date, etc.",
                "Invoices → extracts invoice_no, customer, items, amounts, dates, etc.",
                "Contracts → extracts parties, dates, terms, obligations, etc.",
                "Reports → extracts key metrics, findings, dates, etc.",
                "ANY document type → AI intelligently extracts relevant data"
            ]
        },
        {
            "name": "send_whatsapp",
            "url": "http://localhost:8000/api/whatsapp/send",
            "method": "POST",
            "description": "Send WhatsApp message via Twilio",
            "category": "messaging",
            "input": {
                "to": "Phone number with country code (e.g., +60123456789)",
                "message": "Message text to send"
            },
            "output": {
                "success": "boolean",
                "message_sid": "Twilio message SID",
                "status": "Message status (queued, sent, delivered, failed)",
                "to": "Recipient phone number",
                "error": "Error message if failed (optional)"
            },
            "use_cases": [
                "Send welcome message to new employee",
                "Notify team of database updates",
                "Send reminders or alerts",
                "Delivery confirmations"
            ]
        },
        {
            "name": "send_email",
            "url": "http://localhost:8000/api/email/send",
            "method": "POST",
            "description": "Send freeform email via SMTP (Gmail)",
            "category": "email",
            "input": {
                "to": "Recipient email address",
                "subject": "Email subject",
                "html": "HTML email body (optional)",
                "text": "Plain text email body (optional)"
            },
            "output": {
                "success": "boolean",
                "message_id": "Unique message identifier",
                "error": "Error message if failed (optional)"
            },
            "use_cases": [
                "Send custom/dynamic emails",
                "Ad-hoc notifications",
                "Manual email campaigns"
            ]
        },
        {
            "name": "send_templated_email",
            "url": "http://localhost:8000/api/email/send-templated",
            "method": "POST",
            "description": "Send templated email using Jinja2 templates",
            "category": "email",
            "input": {
                "to": "Recipient email address",
                "template": "Template name (e.g., 'onboarding_welcome', 'payroll_notification')",
                "subject": "Email subject",
                "variables": "Object with template variables (varies by template)"
            },
            "output": {
                "success": "boolean",
                "message_id": "Unique message identifier",
                "error": "Error message if failed (optional)"
            },
            "templates_available": [
                {
                    "name": "onboarding_welcome",
                    "variables": {
                        "employee_name": "Employee full name",
                        "title": "Job title/position",
                        "email": "Work email",
                        "phone": "Contact phone"
                    }
                },
                {
                    "name": "payroll_notification",
                    "variables": {
                        "employee_name": "Employee full name",
                        "month": "Payroll month (1-12)",
                        "year": "Payroll year",
                        "role": "Employee role/position",
                        "salary": "Base salary",
                        "gross_salary": "Gross before deductions",
                        "tax_amount": "Income tax (PCB)",
                        "epf_individual_amount": "Employee's EPF deduction",
                        "epf_percentage_employee": "EPF % for employee",
                        "epf_company_amount": "Company's EPF contribution",
                        "epf_percentage_company": "EPF % for company",
                        "total_salary": "Final take-home salary"
                    }
                }
            ],
            "use_cases": [
                "HR onboarding: welcome new employees",
                "Payroll: send monthly payslips",
                "Structured HR communications",
                "Template-driven notifications"
            ]
        },
        {
            "name": "create_calendar_meeting",
            "url": "http://localhost:8000/api/calendar/create",
            "method": "POST",
            "description": "Create Google Calendar event with Google Meet link",
            "category": "calendar",
            "input": {
                "summary": "Meeting title",
                "description": "Meeting description (optional)",
                "start_time": "ISO-8601 datetime string (e.g., '2026-02-15T14:00:00')",
                "end_time": "ISO-8601 datetime string",
                "attendees": "List of email addresses to invite",
                "timezone": "Timezone (e.g., 'Asia/Kuala_Lumpur', default: 'UTC')",
                "send_notifications": "Send notification emails to attendees (boolean, default: true)"
            },
            "output": {
                "event_id": "Google Calendar event ID",
                "html_link": "Link to calendar event",
                "meet_link": "Google Meet URL for the conference",
                "error": "Error message if failed (optional)"
            },
            "use_cases": [
                "Schedule meetings with video conferencing",
                "Automated interview scheduling",
                "Team meetings with online links",
                "Client calls with Google Meet integration"
            ]
        }
    ],
    "authentication": {
        "type": "optional",
        "method": "API Key in header",
        "header_name": "x-api-key",
        "note": "Set API_KEY in .env to enable authentication. If not set, endpoints are open."
    },
    "base_url": "http://localhost:8000",
    "version": "1.0.0"
}